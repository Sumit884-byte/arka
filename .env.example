# Arka quick-start .env
#
# Copy:  cp .env.example ~/.config/arka/.env
# Then add your API keys and uncomment any overrides you need.
#
# Full reference (all options, grouped by feature):
#   src/arka/env.example
#
# Short names only (no ARKA_ prefix). Legacy ARKA_* keys normalize on load.
# Placeholders like your_key_here are ignored — treated as unset.


# =============================================================================
# LLM — API keys (required for cloud models)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OLLAMA_API_KEY=your_ollama_api_key_here
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=                    # Kimi (alias: KIMI_API_KEY)
# ZAI_API_KEY=                         # Z.AI GLM (aliases: ZHIPUAI_API_KEY, GLM_API_KEY)
# MINIMAX_API_KEY=
# VENICE_API_KEY=
# OPENROUTER_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# PERPLEXITY_API_KEY=
# HF_TOKEN=                            # Hugging Face Inference (aliases: HUGGINGFACE_API_KEY)
# LITELLM_API_KEY=                     # LiteLLM proxy (default http://127.0.0.1:4000/v1)
# LMSTUDIO_API_KEY=                    # LM Studio local (default http://127.0.0.1:1234/v1)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT
# BEDROCK_API_KEY=                     # optional; or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
# VLLM_API_KEY=EMPTY                   # local vLLM (often no real key)
# VLLM_CLOUD_API_KEY=                  # remote vLLM OpenAI-compatible endpoint

# =============================================================================
# LLM — preference (defaults work without changes)
# =============================================================================
OLLAMA_HOST=0.0.0.0:11434
AI_PREFERRED_PROVIDER=gemini
AI_PREFERRED_MODEL=gemini-2.0-flash

# =============================================================================
# Agent identity
# =============================================================================
AGENT_NAME=arka
AGENT_WAKE_WORDS=hey arka,arka

# =============================================================================
# LLM — fallback chain (optional; defaults work without changes)
# =============================================================================
# LLM_FALLBACK=gemini:gemini-2.5-flash,groq:llama-3.3-70b-versatile   # full override
# LLM_FALLBACK_CHAIN=                  # alias for LLM_FALLBACK
# LLM_FALLBACK_GUIDANCE=groq:llama-3.3-70b-versatile  # prepend to auto chain
# ROUTE_MODEL=groq/llama-3.1-8b-instant # NL router LLM (task=route); ROUTING_MODEL alias
# SKILL_MODEL_CHAT=gemini-2.5-flash     # per-task prepend (SKILL_MODEL_<TASK>)
# SKILL_MODEL_WEB_ANSWER=groq/llama-3.3-70b-versatile  # per-skill prepend (SKILL_MODEL_<SKILL>)
# SKILL_MODELS={"chat":"gemini-2.5-flash","web_answer":"groq/llama-3.3-70b-versatile"}  # inline JSON map
# LLM_SKILL_MODELS=~/.config/arka/llm-skill-models.json  # per-skill file (ai-skill-model / skill-models)

# AGENT_SPEAK=1                        # speak replies on arka listen
# SPEAK_LANG=en-IN
# AGENT_WAKE_AUTO=1                    # auto-start wake listener on shell open
# LLM_AUTO_FALLBACK=1                  # try next model/provider on errors (default on)
# SECURITY=1                           # master security switch (default on)
# SUPERMEMORY_API_KEY=                 # cloud long-term memory
# ASSEMBLYAI_API_KEY=                  # best wake-word STT for arka listen
# SARVAM_API_KEY=                      # Indian English/Hindi cloud TTS/STT
# REMOTE_PORT=8765                     # phone → PC bridge (arka serve)
# USAGE_TRACK=1                        # app/website time tracking
