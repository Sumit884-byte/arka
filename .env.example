# AI Provider API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OLLAMA_API_KEY=your_ollama_api_key_here

# Ollama Configuration
OLLAMA_HOST=0.0.0.0:11434

# AI Preference — model-agnostic via Agno (pip install -r arka_chat_requirements.txt in venv-arka)
# AI_PREFERRED_PROVIDER=gemini   # gemini | groq | ollama | openai | anthropic
# AI_PREFERRED_MODEL=gemini-2.0-flash
# ARKA_LLM_AUTO_FALLBACK=1       # try next provider/model on quota/key errors (default on)
# ARKA_LLM_FALLBACK=gemini:gemini-2.0-flash,groq:llama-3.3-70b-versatile,groq:llama-3.1-8b-instant,ollama:llama3.2:1b
# ARKA_LLM_FALLBACK_SUMMARIZE=   # per-task chain (also: ROUTE, CHAT, RESEARCH, AGENT, PDF, PREDICTIONS)
# ARKA_LLM_FALLBACK_NOTIFY=1     # stderr when a later provider/model succeeds
# ARKA_LLM_VERBOSE=1             # log each provider/model attempt
# ARKA_LLM_AUTO_START_SERVERS=1  # start Ollama/vLLM when needed (default on)
# ARKA_LLM_AUTO_STOP_SERVERS=1   # stop servers Arka started after use (default on)
# ARKA_LLM_SERVER_START_TIMEOUT=15
# ARKA_VLLM_START_CMD=vllm serve --model meta-llama/Llama-3.2-3B-Instruct --port 8000
# ARKA_LLM_PROVIDER=             # alias for AI_PREFERRED_PROVIDER
# ARKA_LLM_MODEL=                # alias for AI_PREFERRED_MODEL
# GEMINI_API_KEY is auto-mapped to GOOGLE_API_KEY for Agno Gemini
#
# NL command routing (agent / arka ask / voice)
# ARKA_ROUTE_MODE=symbolic       # default: symbolic rules first, AI fallback
# ARKA_ROUTE_MODE=ai             # AI first, symbolic fallback
# ARKA_ROUTE_MODE=symbolic_only  # symbolic/offline rules only (no LLM routing)
# ARKA_ROUTE_MODE=ai_only        # LLM routing only (no symbolic rules)
#
# Security — symbolic verification before web search and risky actions
# ARKA_SECURITY=1                # master switch (default on)
# ARKA_SECURITY_WEB=1            # block prompt-injection in web/search queries
# ARKA_SECURITY_ACTIONS=1        # confirm install/delete/send/download before run
# ARKA_SECURITY_SANITIZE=1       # strip injection patterns from scraped web text

# Agent identity (default name: arka)
AGENT_NAME=arka
AGENT_WAKE_WORDS=hey arka,arka
# Wake listener is OFF by default — run: arka listen
# AGENT_WAKE_AUTO=1          # auto-start wake listener on shell open
# Speech-to-text (wake listener on PC mic)
# ARKA_STT=auto              # auto | assemblyai | groq | sarvam | vosk
#                            # listen command chain: AssemblyAI → Sarvam → Vosk (when auto + keys set)
# ARKA_LISTEN_ENGINE=auto    # auto | assemblyai | vosk — auto streams everything (wake + command)
#                            # through AssemblyAI when ASSEMBLYAI_API_KEY is set (far better wake accuracy);
#                            # vosk forces fully-offline wake detection
# ASSEMBLYAI_API_KEY=        # https://www.assemblyai.com/dashboard/api-keys (command STT for arka listen)
# ARKA_ASSEMBLYAI_REGION=us  # us | eu | us-pinned (streaming host)
# ARKA_ASSEMBLYAI_REALTIME_MODEL=universal-3-5-pro
# ARKA_ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2
# ARKA_VOSK_TIER=medium      # small | medium | best — medium picks Indian English model for *-IN locales
# ARKA_VOSK_PRESET=small-in  # small-us | small-in | medium-us | best-in
# ARKA_MIC_DEVICE=           # pactl list sources short — e.g. alsa_input.usb-...
# ARKA_COMMAND_SECONDS=10    # seconds to capture command after wake word
# ARKA_AUTO_START=1          # start remote server on shell open (not listen unless AGENT_WAKE_AUTO=1)
# ARKA_USAGE_TRACK=1      # track app + website time (starts on login)
# ARKA_WEB_TRACK=1        # website/domain tracking (Brave, Chrome, Firefox)
#
# AIE (Artificial Internet Enhancements) — background desktop helpers
# ARKA_AIE_DIR=              # override script dir (default: bundled aie/ in arka home)
# AIE_WATCH_DIR=             # folder for zip/classify watchers (default: ~/Downloads)
# AIE_DOWNLOADS_DIR=         # cleanup target (default: ~/Downloads)
# AIE_POLL_SECONDS=2         # watcher poll interval
#
# WhatsApp inbox → Arka (see README § Phone, Termux & WhatsApp; branch: feature/phone-whatsapp-termux)
# ARKA_WHATSAPP_FROM=+919876543210        # comma-separated allowed senders (required for inbox)
# ARKA_WHATSAPP_SELF=auto                  # auto | 1 | 0 — watch “You” / message-yourself when one number
# ARKA_WHATSAPP_CHAT=You                   # extra sidebar chat titles (comma-separated)
# ARKA_WHATSAPP_BOT_PREFIX=🤖              # prefix on Arka replies; messages with this prefix are ignored
# ARKA_WHATSAPP_BACKEND=auto               # auto | desktop | web — macOS defaults to native WhatsApp.app
# ARKA_WHATSAPP_APP=WhatsApp               # macOS app name if not /Applications/WhatsApp.app
# ARKA_WHATSAPP_AUTO_SEND=1                # press Enter to send after whatsapp:// opens (macOS)
# ARKA_WHATSAPP_REPLY=1                  # reply in app / via send
# ARKA_WHATSAPP_POLL=5                   # poll interval seconds
# ARKA_WHATSAPP_DEBUG=0                  # log JSON lines to whatsapp_debug.log
# ARKA_WHATSAPP_DIR=                     # override bundled whatsapp/ automation scripts
# YOUTUBE_BULK_DOWNLOAD_DIR=~/Videos/YoutubeDownloads   # playlist/channel save root (default)
# YOUTUBE_BULK_DIR=                  # optional external youtube_bulk_downloader app path
# ARKA_YT_TRANSCRIBE_FALLBACK=ask    # ask | yes | no — when captions missing, download + STT?
# ARKA_YT_COOKIES_BROWSER=chrome     # optional — helps fetch captions when API is blocked
#
# Stock & market (optional stock_analysis project for prices/ML/context)
# ARKA_STOCK_PROJECT=~/Projects/python/products/stock_analysis
#
# Reminders (survives shutdown; re-fires when you're back if PC was idle/off)
# ARKA_REMIND_IDLE_SEC=300        # idle threshold — also remind when you return
# ARKA_REMIND_ACTIVE_SEC=60       # keyboard/mouse within N sec = "using PC"
# ARKA_REMIND_SPEAK=0             # 1 = speak reminder aloud
# Voice replies (Sarvam API if key set, else Indic Parler-TTS local)
# AGENT_SPEAK=1
# AGENT_SPEAK_MAX=900   # chars read aloud per arka listen reply (plain spoken language)
# ARKA_VOICE_SESSION_TURNS=8  # follow-up context for "and what about..." without re-waking
# AGENT_TTS=auto          # auto | sarvam | edge | parler | system
# ARKA_SPEAK_LANG=en-IN
# ARKA_LISTEN_STT_LANG=en-IN   # optional: STT in English while TTS stays hi-IN (less Devanagari in transcripts)
# SARVAM_STT_MODE=translit     # transcribe | translit | verbatim | codemix
# ARKA_SPEAK_GENDER=female             # female | male (when voice not set)
# ARKA_SPEAK_RATE=-5%                  # slightly slower = more natural

# Sarvam Bulbul v3 (optional cloud TTS — used when SARVAM_API_KEY is set)
# SARVAM_API_KEY=your_key_here
# SARVAM_TTS_SPEAKER=shubh

# Indic Parler-TTS (default local voice when no Sarvam key)
# First time: arka tts-setup   then   arka speak-lang hi-IN
# Languages: en-IN hi-IN ta-IN te-IN bn-IN mr-IN gu-IN kn-IN ml-IN pa-IN or-IN as-IN ur-IN sa-IN

# Remote phone → PC (phone does STT/TTS, PC runs heavy agent/LLM)
# PC: arka serve   |   Phone browser: http://PC_IP:8765/   |   Termux: arka phone-env
# ARKA_REMOTE_HOST=0.0.0.0
# ARKA_REMOTE_PORT=8765
# ARKA_REMOTE_TOKEN=auto-generated on first 'arka serve'
# ARKA_REMOTE_URL=http://192.168.1.5:8765   # paste into Termux ~/.arka/env

# Then: arka install torch   |   arka listen   |   say "hey arka, what's the weather"

# Third-party skills (plugins) — folders with skill.json or *.fish
# ARKA_SKILLS_PATH=~/my-arka-plugins   # extra search paths (colon-separated)
# Install: arka skills install /path/to/skill  or  arka skills install <git-url>
# Default dirs: ~/.config/arka/skills/  and  $ARKA_HOME/skills/

# Supermemory (cloud long-term memory — API first, local cache fallback)
# Get key: https://supermemory.ai/docs/quickstart
# SUPERMEMORY_API_KEY=
# ARKA_SUPERMEMORY_CONTAINER=arka      # container tag (defaults to AGENT_NAME)
# ARKA_MEMORY=auto                     # auto | supermemory | local
# ARKA_MEMORY_AUTODETECT=1             # symbolic autodetect from NL chat/voice (default on)
# ARKA_SHOW_MODEL=1                    # show provider/model under answers (default on; set 0 to hide)

# Spotify search (optional — free Developer Dashboard app, no Premium needed for search)
# SPOTIPY_CLIENT_ID=
# SPOTIPY_CLIENT_SECRET=
# Or: SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET
# macOS: install Spotify.app — playback via AppleScript (no API key required)
# Linux: spotify desktop + playerctl for auto-play

# PDF_INPUT_DIR=/path/to/pdfs
# PDF_OUTPUT_DIR=/path/to/output
# PDF_PASSWORD=your_default_password