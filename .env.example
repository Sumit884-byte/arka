# ROUTE_MODE=symbolic  # symbolic (default) | ai_only — NL routing before LLM
# Arka quick-start .env
#
# Copy:  cp .env.example ~/.config/arka/.env
# Then add your API keys and uncomment any overrides you need.
#
# Full reference (all options, grouped by feature):
#   src/arka/env.example
#
# Short names only (no ARKA_ prefix). Legacy ARKA_* keys normalize on load.
# Placeholders like your_key_here are ignored — treated as unset.


# =============================================================================
# LLM — API keys (required for cloud models)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OLLAMA_API_KEY=your_ollama_api_key_here
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=                    # Kimi (alias: KIMI_API_KEY)
# ZAI_API_KEY=                         # Z.AI GLM (aliases: ZHIPUAI_API_KEY, GLM_API_KEY)
# MINIMAX_API_KEY=
# VENICE_API_KEY=
# OPENROUTER_API_KEY=
# SAKANA_API_KEY=                      # Sakana Fugu orchestrator (alias provider: fugu)
# SAKANA_API_BASE=https://api.sakana.ai/v1
# SAKANA_MODELS=fugu,fugu-ultra
# MISTRAL_API_KEY=
# COHERE_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# PERPLEXITY_API_KEY=
# HF_TOKEN=                            # Hugging Face Inference (aliases: HUGGINGFACE_API_KEY)

# =============================================================================
# 3D generation (compose_3d — free backends + procedural fallback)
# =============================================================================
# TRIPO_API_KEY=                       # Tripo AI — 300 free credits at platform.tripo3d.ai
# MESHY_API_KEY=                       # Meshy API (Pro+ plan; web free tier is UI-only)
# HF_SHAP_E_SPACE=hysts/Shap-E         # HuggingFace Gradio space for text-to-3D
# MODEL_3D_BACKEND=auto                # auto | procedural | tripo | hf-shap-e | shap-e | meshy | openscad | llm
# MODEL_3D_OUTPUT_DIR=~/Models/arka-generated
# SHAP_E_DEVICE=cuda                   # local Shap-E only (pip install torch diffusers)
# LITELLM_API_KEY=                     # LiteLLM proxy (default http://127.0.0.1:4000/v1)
# LMSTUDIO_API_KEY=                    # LM Studio local (default http://127.0.0.1:1234/v1)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT
# BEDROCK_API_KEY=                     # optional; or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
# VLLM_API_KEY=EMPTY                   # local vLLM (often no real key)
# VLLM_CLOUD_API_KEY=                  # remote vLLM OpenAI-compatible endpoint

# =============================================================================
# LLM — preference (defaults work without changes)
# =============================================================================
OLLAMA_HOST=0.0.0.0:11434
AI_PREFERRED_PROVIDER=gemini
AI_PREFERRED_MODEL=gemini-2.0-flash
# AI_PREFERRED_PROVIDER=openrouter
# AI_PREFERRED_MODEL=anthropic/claude-3.5-sonnet
#
# Preferred provider CLI:
#   arka provider list | set <provider> | models | show
# OPENROUTER_LIST=1                    # fetch live OpenRouter models (default on with key)

# =============================================================================
# Agent identity
# =============================================================================
AGENT_NAME=arka
AGENT_WAKE_WORDS=hey arka,arka

# =============================================================================
# LLM — fallback chain (optional; defaults work without changes)
# =============================================================================
# LLM_FALLBACK=gemini:gemini-2.5-flash,groq:llama-3.3-70b-versatile   # full override
# LLM_FALLBACK_CHAIN=                  # alias for LLM_FALLBACK
# LLM_FALLBACK_GUIDANCE=groq:llama-3.3-70b-versatile  # prepend to auto chain
# ROUTE_MODEL=groq/llama-3.1-8b-instant # NL router LLM (task=route); ROUTING_MODEL alias
# SKILL_MODEL_CHAT=gemini-2.5-flash     # per-task prepend (SKILL_MODEL_<TASK>)
# SKILL_MODEL_WEB_ANSWER=groq/llama-3.3-70b-versatile  # per-skill prepend (SKILL_MODEL_<SKILL>)
# SKILL_MODELS={"chat":"gemini-2.5-flash","web_answer":"groq/llama-3.3-70b-versatile"}  # inline JSON map
# LLM_SKILL_MODELS=~/.config/arka/llm-skill-models.json  # per-skill file (ai-skill-model / skill-models)

# AGENT_SPEAK=1                        # speak replies on arka listen
# SPEAK_LANG=en-IN
# AGENT_WAKE_AUTO=1                    # auto-start wake listener on shell open
# LLM_AUTO_FALLBACK=1                  # try next model/provider on errors (default on)
# SECURITY=1                           # master security switch (default on)
# SUPERMEMORY_API_KEY=                 # cloud long-term memory
# ASSEMBLYAI_API_KEY=                  # best wake-word STT for arka listen
# SARVAM_API_KEY=                      # Indian English/Hindi cloud TTS/STT
# REMOTE_PORT=8765                     # phone → PC bridge (arka serve)
# USAGE_TRACK=1                        # app/website time tracking

# =============================================================================
# Kalshi — prediction markets (optional; public read endpoints need no key)
# =============================================================================
# KALSHI_API_KEY=                      # only for authenticated Trade API endpoints
# KALSHI_API_BASE=https://external-api.kalshi.com/trade-api/v2

# =============================================================================
# Network — outbound proxy / VPN (optional)
# =============================================================================
# Standard vars (curl, Python urllib, httpx, requests):
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:1080
# NO_PROXY=localhost,127.0.0.1,.local
#
# Arka aliases (ARKA_* keys normalize on load):
# ARKA_PROXY=http://127.0.0.1:7890       # → PROXY; applied to HTTP/HTTPS when unset
# ARKA_NO_PROXY=localhost,127.0.0.1      # → NO_PROXY
# ARKA_PROXY_ENABLED=1                   # → PROXY_ENABLED; 0 disables apply_proxy_env
# ARKA_VPN_PROXY=http://127.0.0.1:7890   # → VPN_PROXY; used when a VPN interface is up
# ARKA_VPN_INTERFACE=utun4               # → VPN_INTERFACE; extra interface to treat as VPN
#
# CLI: arka proxy status | test | on | off | rotate | list | use <index|url>
#
# Proxy pool / rotation (optional):
# ARKA_PROXY_LIST=http://127.0.0.1:7890,http://127.0.0.1:7891,socks5://127.0.0.1:1080
# ARKA_PROXY_LIST_FILE=~/.config/arka/proxies.txt   # one URL per line or JSON array
# ARKA_PROXY_ROTATION=round-robin                   # round-robin | random | sticky
# ARKA_PROXY_ROTATE_ON_FAIL=1                       # auto-advance pool when proxy test fails
