      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "traces",
              "queryName": "A",
              "expression": "service.name = arka AND name = arka.request",
              "aggregateOperator": "count",
              "aggregateAttribute": {},
              "filters": {
                "items": [],
                "op": "AND"
              },
              "groupBy": [],
              "orderBy": [],
              "limit": null,
              "stepInterval": 60,
              "disabled": false
