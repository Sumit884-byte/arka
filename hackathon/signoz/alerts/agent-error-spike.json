{
  "alert": "Arka agent error spike",
  "alertType": "TRACES_BASED_ALERT",
  "ruleType": "threshold_rule",
  "version": "v5",
  "schemaVersion": "v2alpha1",
  "evalWindow": "10m0s",
  "frequency": "1m0s",
  "description": "More than {{$threshold}} error spans from the arka service in the evaluation window (current: {{$value}}).",
  "summary": "Arka agent error span count above threshold",
  "disabled": false,
  "labels": {
    "severity": "warning",
    "team": "arka",
    "hackathon": "agents-of-signoz"
  },
  "condition": {
    "compositeQuery": {
      "queryType": "builder",
      "panelType": "graph",
      "queries": [
        {
          "type": "builder_query",
          "spec": {
            "name": "A",
            "signal": "traces",
            "stepInterval": 60,
            "aggregations": [
              {
                "expression": "count()"
              }
            ],
            "filter": {
              "expression": "service.name = 'arka' AND status = 'error'"
            },
            "groupBy": [
              {
                "name": "service.name",
                "fieldContext": "resource",
                "fieldDataType": "string"
              }
            ],
            "legend": "{{service.name}}"
          }
        }
      ]
    },
    "selectedQueryName": "A",
    "thresholds": {
      "kind": "basic",
      "spec": [
        {
          "name": "warning",
          "op": "above",
          "matchType": "at_least_once",
          "target": 5,
          "targetUnit": "",
          "recoveryTarget": null,
          "channels": []
        }
      ]
    }
  },
  "evaluation": {
    "kind": "rolling",
    "spec": {
      "evalWindow": "10m0s",
      "frequency": "1m0s"
    }
  },
  "notificationSettings": {
    "groupBy": ["service.name"],
    "renotify": {
      "enabled": true,
      "interval": "30m0s",
      "alertStates": ["firing"]
    },
    "usePolicy": false
  }
}
