# Arka settings — short names in .env (no ARKA_ prefix).

# AI Provider API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OLLAMA_API_KEY=your_ollama_api_key_here
# Multiple keys per provider (auto-rotate on 429/quota/key errors — default on)
# GEMINI_API_KEYS=key2,key3
# GROQ_API_KEYS=key2,key3
# GEMINI_API_KEY_2=backup_key
# GROQ_API_KEY_2=backup_key
# API_KEY_ROTATION=1

# Ollama Configuration
OLLAMA_HOST=0.0.0.0:11434

# AI Preference — model-agnostic via Agno (pip install -r arka_chat_requirements.txt in venv-arka)
AI_PREFERRED_PROVIDER=gemini
AI_PREFERRED_MODEL=gemini-2.0-flash
# Gemini model list tried in order (merged with live ListModels when API key is set)
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite
# GEMINI_LIST=1              # fetch generateContent models from Gemini API (default on with key)
# Groq model list (merged with live /openai/v1/models when GROQ_API_KEY is set)
# GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
# GROQ_LIST=1                # fetch models from Groq API (default on with key)
# Ollama model list (merged with live /api/tags when ollama is reachable)
# OLLAMA_MODELS=minimax-m2.5:cloud,qwen3:8b,llama3.2:1b
# OLLAMA_LIST=1              # fetch installed models from Ollama (default on when reachable)
# LLM_AUTO_FALLBACK=1       # try next provider/model on quota/key errors (default on)
# LLM_FALLBACK=gemini:gemini-2.5-flash,gemini:gemini-2.0-flash,groq:llama-3.3-70b-versatile,groq:llama-3.1-8b-instant,ollama:minimax-m2.5:cloud
# LLM_FALLBACK_SUMMARIZE=   # per-task chain (also: ROUTE, CHAT, RESEARCH, AGENT, PDF, PREDICTIONS)
# LLM_FALLBACK_NOTIFY=1     # stderr when a later provider/model succeeds
# LLM_VERBOSE=1             # log each provider/model attempt
# LLM_AUTO_START_SERVERS=1  # start Ollama/vLLM when needed (default on)
# LLM_AUTO_STOP_SERVERS=1   # stop servers Arka started after use (default on)
# LLM_SERVER_START_TIMEOUT=15
# VLLM_START_CMD=vllm serve --model meta-llama/Llama-3.2-3B-Instruct --port 8000
# LLM_PROVIDER=             # alias for AI_PREFERRED_PROVIDER
# LLM_MODEL=                # alias for AI_PREFERRED_MODEL
# GEMINI_API_KEY is auto-mapped to GOOGLE_API_KEY for Agno Gemini
#
# NL command routing (agent / arka ask / voice)
# ROUTE_MODE=symbolic       # default: symbolic rules first, AI fallback
# ARKA_NATIVE_LANG=hindi    # your language for survive_lang travel phrases (default: English or ARKA_SPEAK_LANG)
# ROUTE_MODE=ai             # AI first, symbolic fallback
# ROUTE_MODE=symbolic_only  # symbolic/offline rules only (no LLM routing)
# ROUTE_MODE=ai_only        # LLM routing only (no symbolic rules)
#
# Research (arka research / agent_research --deep)
# RESEARCH_MIN_WORDS=500      # target lower bound for answer length
# RESEARCH_MAX_WORDS=900      # target upper bound for answer length
# RESEARCH_SCRAPE_MIN_WORDS=700   # min scraped web text before stopping (deep mode default)
# RESEARCH_SCRAPE_PAGES=10    # max pages to scrape per query (deep mode default)
#
# Security — symbolic verification before web search, LLM calls, and risky actions
# SECURITY=1                # master switch (default on)
# SECURITY_WEB=1            # block prompt-injection in web/search queries
# SECURITY_LLM=1            # verify prompts + sanitize context on every LLM call
# SECURITY_ACTIONS=1        # confirm install/delete/send/download before run
# SECURITY_SANITIZE=1       # strip injection patterns from untrusted LLM context

# Agent identity (default name: arka)
AGENT_NAME=arka
AGENT_WAKE_WORDS=hey arka,arka
# Wake listener is OFF by default — run: arka listen
# AGENT_WAKE_AUTO=1          # auto-start wake listener on shell open
# Speech-to-text (wake listener on PC mic)
# STT=auto              # auto | assemblyai | groq | sarvam | vosk
#                            # listen command chain: AssemblyAI → Sarvam → Vosk (when auto + keys set)
# LISTEN_ENGINE=auto    # auto | assemblyai | vosk — auto streams everything (wake + command)
#                            # through AssemblyAI when ASSEMBLYAI_API_KEY is set (far better wake accuracy);
#                            # vosk forces fully-offline wake detection
# ASSEMBLYAI_API_KEY=        # https://www.assemblyai.com/dashboard/api-keys (command STT for arka listen)
# ASSEMBLYAI_REGION=us  # us | eu | us-pinned (streaming host)
# ASSEMBLYAI_REALTIME_MODEL=universal-3-5-pro
# ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2
# VOSK_TIER=medium      # small | medium | best — medium picks Indian English model for *-IN locales
# VOSK_PRESET=small-in  # small-us | small-in | medium-us | best-in
# MIC_DEVICE=           # pactl list sources short — e.g. alsa_input.usb-...
# COMMAND_SECONDS=10    # seconds to capture command after wake word
# AUTO_START=1          # start remote server on shell open (not listen unless AGENT_WAKE_AUTO=1)
# USAGE_TRACK=1      # track app + website time (starts on login)
# WEB_TRACK=1        # website/domain tracking (Brave, Chrome, Firefox)
#
# AIE (Artificial Internet Enhancements) — background desktop helpers
# AIE_DIR=              # override script dir (default: bundled aie/ in arka home)
# AIE_WATCH_DIR=             # folder for zip/classify watchers (default: ~/Downloads)
# AIE_DOWNLOADS_DIR=         # cleanup target (default: ~/Downloads)
# AIE_POLL_SECONDS=2         # watcher poll interval
#
# YOUTUBE_BULK_DOWNLOAD_DIR=~/Videos/YoutubeDownloads   # playlist/channel save root (default)
# YOUTUBE_BULK_DIR=                  # optional external youtube_bulk_downloader app path
# YT_TRANSCRIBE_FALLBACK=ask    # ask | yes | no — when captions missing, download + STT?
# YT_COOKIES_BROWSER=chrome     # optional — helps fetch captions when API is blocked
#
# Stock & market (optional stock_analysis project for prices/ML/context)
# PROFESSIONS_ROOT=~/Projects/professions
# STOCK_PROJECT=~/Projects/professions/investor/stock_analyzer
# Profession project dirs (symbolic open: profession open startup)
# PROFESSION_STARTUP_PROJECT=~/Projects/my-startup
# PROFESSION_DOCTOR_PROJECT=~/Projects/clinic-app
# PROFESSION_NUTRITIONIST_PROJECT=~/Projects/nutrition-coach
# Or JSON map: ARKA_PROFESSION_PROJECTS={"startup":"~/Projects/my-startup","doctor":"~/Projects/clinic-app"}
#
# Reminders (survives shutdown; re-fires when you're back if PC was idle/off)
# REMIND_DEFAULT=1h         # when no time given: remind to … / remind stretch
# REMIND_IDLE_SEC=300        # idle threshold — also remind when you return
# REMIND_ACTIVE_SEC=60       # keyboard/mouse within N sec = "using PC"
# REMIND_SPEAK=0             # 1 = speak reminder aloud
# Voice replies (Sarvam API if key set, else Indic Parler-TTS local)
# AGENT_SPEAK=1
# AGENT_SPEAK_MAX=900   # chars read aloud per arka listen reply (plain spoken language)
# VOICE_SESSION_TURNS=8  # follow-up context for "and what about..." without re-waking
# AGENT_TTS=auto          # auto | sarvam | edge | parler | system
# SPEAK_LANG=en-IN
# LISTEN_STT_LANG=en-IN   # optional: STT in English while TTS stays hi-IN (less Devanagari in transcripts)
# SARVAM_STT_MODE=translit     # transcribe | translit | verbatim | codemix
# SPEAK_GENDER=female             # female | male (when voice not set)
# SPEAK_RATE=-5%                  # slightly slower = more natural

# Sarvam Bulbul v3 (optional cloud TTS — used when SARVAM_API_KEY is set)
# SARVAM_API_KEY=your_key_here
# SARVAM_TTS_SPEAKER=shubh

# Indic Parler-TTS (default local voice when no Sarvam key)
# First time: arka tts-setup   then   arka speak-lang hi-IN
# Languages: en-IN hi-IN ta-IN te-IN bn-IN mr-IN gu-IN kn-IN ml-IN pa-IN or-IN as-IN ur-IN sa-IN

# Remote phone → PC (phone does STT/TTS, PC runs heavy agent/LLM)
# REMOTE_HOST=0.0.0.0
# REMOTE_PORT=8765
# REMOTE_TOKEN=auto-generated on first 'arka serve' (legacy prefix ARKA_ still accepted)
# REMOTE_URL=http://192.168.1.5:8765

# Then: arka install torch   |   arka listen   |   say "hey arka, what's the weather"

# Third-party skills (plugins) — folders with skill.json or *.fish
# SKILLS_PATH=~/my-arka-plugins   # extra search paths (colon-separated)
# PROFESSIONS_PATH=~/my-professions   # extra third-party profession plugin dirs (colon-separated)
# ARKA_PROFESSION_EXAMPLES=1   # load bundled example professions (dev/demo only)
# Install: arka skills install /path/to/skill  or  arka skills install <git-url>
# Default dirs: ~/.config/arka/skills/  and  $INSTALL_HOME/skills/ or skills dir under config

# Third-party professions — folders with profession.json (RSS, search_bias, aliases, keywords)
# PROFESSIONS_PATH=~/my-professions   # extra search paths (colon-separated)
# Install: profession install /path/to/profession  or  profession install <git-url>
# Default dir: ~/.config/arka/professions/
# Example bundle: src/arka/professions/examples/architect/

# Supermemory (cloud long-term memory — API first, local cache fallback)
# Get key: https://supermemory.ai/docs/quickstart
# SUPERMEMORY_API_KEY=
# SUPERMEMORY_CONTAINER=arka      # container tag (defaults to AGENT_NAME)
# MEMORY=auto                     # auto | supermemory | local
# MEMORY_AUTODETECT=1             # symbolic autodetect from NL chat/voice (default on)
# SHOW_MODEL=1                    # show provider/model under answers (default on; set 0 to hide)

# Spotify search (optional — free Developer Dashboard app, no Premium needed for search)
# SPOTIPY_CLIENT_ID=
# SPOTIPY_CLIENT_SECRET=
# Or: SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET
# macOS: install Spotify.app — playback via AppleScript (no API key required)
# Linux: spotify desktop + playerctl for auto-play

# PDF_INPUT_DIR=/path/to/pdfs
# PDF_OUTPUT_DIR=/path/to/output
# PDF_PASSWORD=your_default_password

# Image generation (generate_image / arka generate_image)
# IMAGE_OUTPUT_DIR=~/Pictures/arka-generated
# IMAGE_BACKEND=auto|nano-banana|pollinations
# OPEN_IMAGE=1

# Info / YouTube video composer (compose_video — Unsplash + ffmpeg + edge-tts)
# Get free Unsplash key: https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=
# VIDEO_OUTPUT_DIR=~/Videos/arka-generated
# VIDEO_FONT=Inter                    # font family name (searched in system font dirs)
# VIDEO_FONT_BOLD=Inter-Bold
# VIDEO_FONT_PATH=/path/to/Regular.ttf   # overrides VIDEO_FONT
# VIDEO_FONT_BOLD_PATH=/path/to/Bold.ttf
# VIDEO_TITLE_FONT_SIZE=72
# VIDEO_BODY_FONT_SIZE=42
# VIDEO_WIDTH=1920
# VIDEO_HEIGHT=1080
# VIDEO_FPS=30
# VIDEO_SCENE_SEC=5                 # seconds per scene when no narration
# VIDEO_CRF=18                      # lower = higher quality (15–23 typical)
# VIDEO_PRESET=medium               # ultrafast|fast|medium|slow
# VIDEO_BG_COLOR=#0f172a
# VIDEO_TEXT_COLOR=#f8fafc
# VIDEO_ACCENT_COLOR=#38bdf8
# VIDEO_TTS=edge                    # edge | none
# VIDEO_TTS_VOICE=en-US-GuyNeural   # edge-tts voice (also SPEAK_VOICE)
# OPEN_VIDEO=1
# VIDEO_COMPOSE_SCRIPT=auto          # auto | llm | template (auto uses LLM when API key set)
# Example: arka compose_video --topic "Python asyncio" --llm
#          arka make youtube video about Rust memory safety

# Google Calendar + Gmail (OAuth browser sign-in)
# 1. Enable Gmail API + Calendar API in Google Cloud Console
# 2. OAuth client → Web application → redirect URI below
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=...
# (aliases: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET also work)
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8766/oauth2callback
# GOOGLE_OAUTH_PORT=8766