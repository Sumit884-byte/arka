# Arka environment reference (canonical)
#
# Copy to ~/.config/arka/.env (macOS/Linux) or %APPDATA%\arka\.env (Windows).
# Dev checkout: arka/.env fills unset vars only (see README "How defaults work").
#
# Conventions:
#   - Short names in .env (no ARKA_ prefix). Legacy ARKA_* keys normalize on load
#     (ARKA_ROUTE_MODE → ROUTE_MODE). Exception: ARKA_HOME → INSTALL_HOME.
#   - Placeholders like your_key_here or changeme are ignored (treated as unset).
#   - Uncomment optional lines to override built-in defaults.
# Quick starter (fewer vars): repo-root .env.example


# =============================================================================
# Paths & install layout
# =============================================================================
# Override where Arka reads config, cache, and bundled scripts.
# INSTALL_HOME=~/dev/arka              # package / script root (legacy: ARKA_HOME)
# CONFIG_DIR=~/.config/arka            # user config (legacy: ARKA_CONFIG_DIR)
# CACHE_DIR=~/.cache/arka              # logs, models, temp (legacy: ARKA_CACHE_DIR)


# =============================================================================
# LLM — API keys (set any you use; orchestrator auto-detects configured keys)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OLLAMA_API_KEY=your_ollama_api_key_here
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=                    # Kimi (alias: KIMI_API_KEY)
# ZAI_API_KEY=                         # Z.AI GLM (aliases: ZHIPUAI_API_KEY, GLM_API_KEY)
# MINIMAX_API_KEY=
# VENICE_API_KEY=
# OPENROUTER_API_KEY=
# LITELLM_API_KEY=                     # LiteLLM proxy (default http://127.0.0.1:4000/v1)
# LMSTUDIO_API_KEY=                    # LM Studio local (default http://127.0.0.1:1234/v1)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT
# BEDROCK_API_KEY=                     # optional; or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
# BEDROCK_API_BASE=                    # optional OpenAI-compatible Bedrock gateway URL
# VLLM_API_KEY=EMPTY                   # local vLLM (often no real key)

# Multiple keys per provider (auto-rotate on 429/quota/key errors — default on)
# GEMINI_API_KEYS=key2,key3
# GROQ_API_KEYS=key2,key3
# GEMINI_API_KEY_2=backup_key
# GROQ_API_KEY_2=backup_key
# API_KEY_ROTATION=1                   # set 0 to disable key rotation


# =============================================================================
# LLM — local servers & preference
# =============================================================================
OLLAMA_HOST=0.0.0.0:11434
# VLLM_HOST=127.0.0.1:8000
# VLLM_API_URL=http://127.0.0.1:8000/v1
# VLLM_MODEL=default
# VLLM_START_CMD=vllm serve --model meta-llama/Llama-3.2-3B-Instruct --port 8000
# Remote vLLM (RunPod, Baseten, custom cloud — OpenAI-compatible /v1/chat/completions)
# VLLM_CLOUD_URL=https://your-endpoint.runpod.net/v1
# VLLM_CLOUD_API_URL=                  # alias for VLLM_CLOUD_URL
# VLLM_CLOUD_API_KEY=your-key
# VLLM_CLOUD_MODEL=meta-llama/Llama-3.2-3B-Instruct
# VLLM_CLOUD_MODELS=model-a,model-b

AI_PREFERRED_PROVIDER=gemini
AI_PREFERRED_MODEL=gemini-2.0-flash
# LLM_PROVIDER=                        # alias for AI_PREFERRED_PROVIDER
# LLM_MODEL=                           # alias for AI_PREFERRED_MODEL

# Model lists (merged with live API lists when keys/servers are reachable)
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite
# GEMINI_LIST=1                        # fetch generateContent models (default on with key)
# GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
# GROQ_LIST=1                          # fetch models from Groq API (default on with key)
# OLLAMA_MODELS=minimax-m2.5:cloud,qwen3:8b,llama3.2:1b
# OLLAMA_LIST=1                        # fetch installed models from Ollama (default on when reachable)

# Failover & server lifecycle (defaults on unless noted)
# LLM_AUTO_FALLBACK=1                  # try next provider/model on quota/key errors
# LLM_FALLBACK=gemini:gemini-2.5-flash,gemini:gemini-2.0-flash,groq:llama-3.3-70b-versatile
# LLM_FALLBACK_CHAIN=                  # alias for LLM_FALLBACK (full override chain)
# LLM_FALLBACK_GUIDANCE=groq:llama-3.3-70b-versatile  # prepend models to auto-built chain
# LLM_FALLBACK_SUMMARIZE=              # per-task full override (also: ROUTE, CHAT, RESEARCH, AGENT, PDF, PREDICTIONS, COMPOSE_VIDEO)
# ROUTE_MODEL=groq/llama-3.1-8b-instant # first model for NL routing (task=route); provider/model or provider:model
# ROUTING_MODEL=groq/llama-3.1-8b-instant             # alias for ROUTE_MODEL
# SKILL_MODEL_CHAT=groq/llama-3.3-70b-versatile       # per-task prepend (SKILL_MODEL_<TASK>; bare model ok)
# SKILL_MODELS={"chat":"gemini-2.5-flash","route":"groq/llama-3.1-8b-instant"}  # inline JSON map
# LLM_SKILL_MODELS=~/.config/arka/llm-skill-models.json # JSON/YAML file map (merged with SKILL_MODELS)
# LLM_FALLBACK_NOTIFY=1                # stderr when a later provider/model succeeds
# LLM_VERBOSE=1                        # log each provider/model attempt
# LLM_AUTO_START_SERVERS=1             # start Ollama/vLLM when needed
# LLM_AUTO_STOP_SERVERS=1              # stop servers Arka started after use
# LLM_SERVER_START_TIMEOUT=15
# GEMINI_API_KEY is auto-mapped to GOOGLE_API_KEY for Agno Gemini


# =============================================================================
# NL routing & research
# =============================================================================
# ROUTE_MODE=symbolic                  # default: symbolic rules first, AI fallback
# ROUTE_MODE=ai                        # AI first, symbolic fallback
# ROUTE_MODE=symbolic_only             # offline rules only (no LLM routing)
# ROUTE_MODE=ai_only                   # LLM routing only (no symbolic rules)
# NATIVE_LANG=hindi                    # survival/travel phrases (code may read ARKA_NATIVE_LANG in shell)

# RESEARCH_MIN_WORDS=500
# RESEARCH_MAX_WORDS=900
# RESEARCH_SCRAPE_MIN_WORDS=700        # deep research: min scraped web text
# RESEARCH_SCRAPE_PAGES=10             # deep research: max pages per query
# MEMORY_SEARCH_FALLBACK=1             # if memory-only answer is unsure, search web (default on)


# =============================================================================
# Security (symbolic checks before web search, LLM calls, risky actions)
# =============================================================================
# SECURITY=1                           # master switch (default on)
# SECURITY_WEB=1                       # block prompt-injection in web/search queries
# SECURITY_LLM=1                       # verify prompts + sanitize context on LLM calls
# SECURITY_ACTIONS=1                   # confirm install/delete/send/download before run
# SECURITY_SANITIZE=1                  # strip injection patterns from untrusted LLM context


# =============================================================================
# Agent identity & display
# =============================================================================
AGENT_NAME=arka
AGENT_WAKE_WORDS=hey arka,arka
# SHOW_MODEL=1                         # show provider/model under answers (default on; set 0 to hide)


# =============================================================================
# Autonomous goal agent (arka goal / loop — Butterfish Goal Mode style)
# =============================================================================
# GOAL_ENGINE=auto                     # auto|arka|butterfish|legacy|off (default: auto)
# GOAL_MAX_STEPS=25
# GOAL_TREE_DEPTH=3
# GOAL_AUTO_CONTINUE=1                 # auto-advance steps without prompting
# GOAL_OUTPUT_LIMIT=8000
# GOAL_SHELL_HISTORY=40                # fish history lines in goal context
# GOAL_CMD_TIMEOUT=300
# AUTO_INSTALL=1                       # skip install prompts (brew/go butterfish, etc.)


# =============================================================================
# Voice — wake listener & speech-to-text (run: arka listen)
# =============================================================================
# Wake listener is OFF by default unless AGENT_WAKE_AUTO=1
# AGENT_WAKE_AUTO=1                    # auto-start wake listener on shell open
# STT=auto                             # auto | assemblyai | groq | sarvam | vosk
# LISTEN_ENGINE=auto                   # auto | assemblyai | vosk
# LISTEN_DEBUG=0
# WAKE_REQUIRED=0                      # require wake word before every command
# ASSEMBLYAI_API_KEY=                  # https://www.assemblyai.com/dashboard/api-keys
# ASSEMBLYAI_REGION=us                 # us | eu | us-pinned (streaming host)
# ASSEMBLYAI_REALTIME_MODEL=universal-3-5-pro
# ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2
# VOSK_TIER=medium                       # small | medium | best
# VOSK_PRESET=small-in                   # small-us | small-in | medium-us | best-in
# VOSK_MODEL=                            # custom model path
# VOSK_MODEL_URL=                        # custom model download URL
# MIC_DEVICE=                            # pactl list sources short (Linux) or CoreAudio name (macOS)
# PULSE_SOURCE=                          # alias for MIC_DEVICE
# COMMAND_SECONDS=10                     # seconds to capture command after wake word
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo


# =============================================================================
# Voice — text-to-speech & session
# =============================================================================
# AGENT_SPEAK=1                          # speak replies aloud (default on for listen)
# AGENT_SPEAK_MAX=900                    # chars read aloud per reply
# VOICE_SESSION_TURNS=8                  # follow-up context without re-waking
# AGENT_TTS=auto                         # auto | sarvam | edge | parler | system
# SPEAK_LANG=en-IN
# LISTEN_STT_LANG=en-IN                  # STT language (can differ from TTS)
# SARVAM_STT_MODE=translit               # transcribe | translit | verbatim | codemix
# SPEAK_VOICE=                           # edge-tts voice override
# SPEAK_GENDER=female                    # female | male (when voice not set)
# SPEAK_RATE=-5%                         # edge-tts rate (slightly slower = more natural)
# SPEAK_PITCH=+0Hz
# SPEAK_SPEAKER=                         # Indic Parler-TTS speaker override
# PARLER_MODEL=ai4bharat/indic-parler-tts

# Sarvam Bulbul v3 (optional cloud TTS — used when SARVAM_API_KEY is set)
# SARVAM_API_KEY=your_key_here
# SARVAM_TTS_SPEAKER=shubh
# SARVAM_TTS_LANG=en-IN

# Indic Parler-TTS (default local voice when no Sarvam key)
# First time: arka tts-setup   then   arka speak-lang hi-IN
# Languages: en-IN hi-IN ta-IN te-IN bn-IN mr-IN gu-IN kn-IN ml-IN pa-IN or-IN as-IN ur-IN sa-IN


# =============================================================================
# Media — transcription, YouTube, batch QA
# =============================================================================
# MEDIA_STT=auto                         # alias: STT (see voice section)
# MEDIA_LANG=                            # defaults to SPEAK_LANG
# MEDIA_PYTHON=                          # Python for media subprocesses
# MEDIA_YOUTUBE=auto
# MEDIA_SUMMARY_CHUNK=12000
# STT_CHUNK_SECONDS=300
# LOCAL_FULL_MAX_SECONDS=1800
# LOCAL_WHISPER_MODEL=small
# HF_STT_MODEL=                          # HuggingFace STT model override
# LOCAL_WHISPER_DEVICE=                  # cuda | cpu
# LOCAL_WHISPER_COMPUTE=                 # float16 | int8
# FORCE_CPU=0
# STT_WORKERS=                           # parallel STT workers
# MEDIA_QA_CONTEXT=14000
# BATCH_MAX_ITEMS=25
# YT_RESEARCH_MAX=2
# YT_RESEARCH_POOL=
# YT_RESEARCH_DELAY=2
# YT_RESEARCH_ALLOW_NO_CAPTION=0
# YT_SKIP_TRANSCRIPT_API=0
# YT_TRANSCRIBE_FALLBACK=ask             # ask | yes | no — when captions missing, download + STT?
# YT_COOKIES_BROWSER=chrome              # helps fetch captions when API is blocked
# YOUTUBE_BULK_DOWNLOAD_DIR=~/Videos/YoutubeDownloads
# YOUTUBE_BULK_DIR=                      # optional external youtube_bulk_downloader app path
# ASK_YT_LIMIT=4
# SPEAK_RESEARCH_TIMEOUT=3600


# =============================================================================
# Session memory & long-term memory (OpenClaw-inspired layer)
# =============================================================================
# SESSION_MEMORY=1                       # markdown MEMORY.md + daily notes (~/.config/arka/agent-memory/)
# SESSION_MEMORY_DIR=                    # override memory root
# MEMORY_LONGTERM_MAX_LINES=100          # prune MEMORY.md wallet limit
# MEMORY_AUTO_LONGTERM=0                 # also append every note to MEMORY.md
# MEMORY=auto                            # auto | supermemory | local
# MEMORY_AUTODETECT=1                    # symbolic autodetect from NL chat/voice (default on)

# Supermemory (cloud long-term memory — API first, local cache fallback)
# Get key: https://supermemory.ai/docs/quickstart
# SUPERMEMORY_API_KEY=
# SUPERMEMORY_CONTAINER=arka             # container tag (defaults to AGENT_NAME)
# SUPERMEMORY_CONTAINER_TAG=             # alias for SUPERMEMORY_CONTAINER


# =============================================================================
# Skills, professions & plugins
# =============================================================================
# SKILLS_PATH=~/my-arka-plugins          # extra skill dirs (colon-separated)
# SKILL_PERMISSIONS=read,write,network,shell
# PROFESSIONS_PATH=~/my-professions      # extra profession plugin dirs (colon-separated)
# PROFESSION_EXAMPLES=0                  # load bundled example professions (dev/demo)
# PROFESSIONS_ROOT=~/Projects/professions
# STOCK_PROJECT=~/Projects/professions/investor/stock_analyzer
# PROFESSION_STARTUP_PROJECT=~/Projects/my-startup
# PROFESSION_DOCTOR_PROJECT=~/Projects/clinic-app
# PROFESSION_NUTRITIONIST_PROJECT=~/Projects/nutrition-coach
# PROFESSION_PROJECTS={"startup":"~/Projects/my-startup"}   # JSON map (legacy: ARKA_PROFESSION_PROJECTS)
# Install: arka skills install /path   |   profession install /path


# =============================================================================
# Routines, reminders & usage tracking
# =============================================================================
# AUTO_START=1                           # start remote server on shell open (not listen unless AGENT_WAKE_AUTO=1)
# USAGE_TRACK=1                          # track app + website time (starts on login)
# WEB_TRACK=1                            # website/domain tracking (Brave, Chrome, Firefox)
# USAGE_INTERVAL=20
# USAGE_IDLE_SEC=120
# ACTIVITYWATCH_URL=http://127.0.0.1:5600

# ROUTINES_SECURITY=1                    # block risky actions in cron (non-interactive)
# ROUTINES_MORNING=09:00
# ROUTINES_EVENING=18:00
# ROUTINES_DAILY=09:00
# ROUTINES_AUTO_INSTALL=0

# REMIND_DEFAULT=1h                      # when no time given: "remind to …"
# REMIND_TICK_SEC=30
# REMIND_GAP_SEC=120
# REMIND_IDLE_SEC=300                    # idle threshold — also remind when you return
# REMIND_ACTIVE_SEC=60                   # keyboard/mouse within N sec = "using PC"
# REMIND_SPEAK=0                         # 1 = speak reminder aloud


# =============================================================================
# Remote server, webhooks & phone bridge
# =============================================================================
# REMOTE_HOST=0.0.0.0
# REMOTE_PORT=8765
# REMOTE_TOKEN=                          # auto-generated on first `arka serve`
# REMOTE_URL=http://192.168.1.5:8765
# REMOTE_TIMEOUT=600

# WEBHOOK_ENABLED=0                      # opt-in verified ingress for external channels
# WEBHOOK_TOKEN=                         # required when enabled (falls back to REMOTE_TOKEN)
# WEBHOOK_HOST=127.0.0.1
# WEBHOOK_PORT=8767
# WEBHOOK_MAX_CHARS=4000
# WEBHOOK_TIMEOUT=300

# HF_BRIDGE_HOST=127.0.0.1               # HuggingFace inference bridge
# HF_BRIDGE_PORT=8787
# HF_BRIDGE_TIMEOUT=180

# WhatsApp inbox (optional)
# WHATSAPP_FROM=+1234567890
# WHATSAPP_REPLY=1
# WHATSAPP_REPLY_MAX=1500
# WHATSAPP_POLL=5
# WHATSAPP_DEBUG=0


# =============================================================================
# Google Workspace — Calendar, Gmail, OAuth
# =============================================================================
# 1. Enable Gmail API + Calendar API in Google Cloud Console
# 2. OAuth client → Web application → redirect URI below
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here
# (aliases: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET)
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8766/oauth2callback
# GOOGLE_OAUTH_PORT=8766
# GOOGLE_OAUTH_KEY=                      # optional encrypted token store key
# GMAIL_MAX=500
# GMAIL_SUMMARIZE_MAX=40
# GMAIL_SUMMARIZE_CHARS=120000
# TZ=Asia/Kolkata                        # calendar timezone (also ARKA_TZ in shell)
# CALENDAR_SOURCES=google,macos          # google | macos (code reads ARKA_CALENDAR_SOURCES in shell)


# =============================================================================
# AIE — Artificial Internet Enhancements (background desktop helpers)
# =============================================================================
# AIE_DIR=                               # override script dir (default: bundled aie/ in arka home)
# AIE_PYTHON=                            # Python for AIE subprocesses
# AIE_WATCH_DIR=                         # folder for zip/classify watchers (default: ~/Downloads)
# AIE_DOWNLOADS_DIR=                     # cleanup target (default: ~/Downloads)
# AIE_POLL_SECONDS=2                     # watcher poll interval


# =============================================================================
# Stock, predictions & codebase RAG (TurboQuant)
# =============================================================================
# USE_FINBERT=0
# STOCK_PLAIN=0                          # plain terminal output (no colors)
# STOCK_TERMINAL=0
# PREDICT_HORIZON=3-6 months
# TURBOQUANT_DIR=                        # TurboQuant repo path
# RAG_BACKEND=turboquant                 # turboquant | ollama
# EMBED_MODEL=nomic-embed-text
# EMBED_DIM=768
# TURBOQUANT_BITS=6
# RAG_CHUNK_CHARS=700
# RAG_TOP_K=24
# RAG_CONTEXT_CHARS=14000
# CODEBASE_MAX_FILES=800
# CODEBASE_MAX_BYTES=524288


# =============================================================================
# PDF / PrivateGPT RAG
# =============================================================================
# PDF_INPUT_DIR=/path/to/pdfs
# PDF_OUTPUT_DIR=/path/to/output
# PDF_PASSWORD=your_default_password
# PDF_RAG_URL=http://127.0.0.1:8001
# PRIVATEGPT_URL=                        # alias for PDF_RAG_URL
# PDF_COLLECTION=default
# PDF_RAG_MODEL=
# PDF_RAG_ASK_MODE=auto                  # auto | search
# PDF_RAG_AUTO_START=1
# PDF_RAG_START_TIMEOUT=120
# PDF_RAG_PGPT=1
# PDF_QUIET=0
# QDRANT_AUTO_START=1


# =============================================================================
# Image & chart generation
# =============================================================================
# IMAGE_OUTPUT_DIR=~/Pictures/arka-generated
# IMAGE_BACKEND=auto                     # auto | nano-banana | pollinations
# IMAGE_MODEL=
# IMAGE_FALLBACK=1
# IMAGE_POLLINATIONS_MODEL=nanobanana
# OPEN_IMAGE=1
# CHART_OUTPUT_DIR=~/Pictures/arka-charts
# OPEN_CHART=1                           # falls back to OPEN_IMAGE

# Drawing / blueprint analysis (PDF, DXF, images)
# DRAWING_MODEL=
# DRAWING_MAX_PAGES=8
# DRAWING_MAX_EDGE=2048
# DRAWING_PDF_ZOOM=2.0
# DRAWING_PDF_DPI=200

# Video generation (arka generate_video)
# VIDEO_BACKEND=auto
# VIDEO_MODEL=
# VIDEO_ASPECT=16:9
# VIDEO_DURATION=5
# VIDEO_AUDIO=1
# VIDEO_POLLINATIONS_MODEL=
# OPEN_VIDEO=1


# =============================================================================
# Info / YouTube video composer (compose_video — stock photos + charts + ffmpeg)
# =============================================================================
# Photo sources (at least one key for B-roll; chart scenes use B-roll after chart hold):
# VIDEO_PHOTO_SOURCES=unsplash,pexels,pixabay,openverse
# Openverse needs no API key (used when other sources fail).
# UNSPLASH_ACCESS_KEY=                   # https://unsplash.com/developers
# PEXELS_API_KEY=                        # https://www.pexels.com/api/
# PIXABAY_API_KEY=                       # https://pixabay.com/api/docs/
# VIDEO_CHART_SEC=15                     # bar/chart hold time before B-roll continues
# VIDEO_MAX_CAPTION_BEATS=6
# VIDEO_OUTPUT_DIR=~/Videos/arka-generated
# VIDEO_FONT=Inter
# VIDEO_FONT_BOLD=Inter-Bold
# VIDEO_FONT_PATH=/path/to/Regular.ttf
# VIDEO_FONT_BOLD_PATH=/path/to/Bold.ttf
# VIDEO_TITLE_FONT_SIZE=72
# VIDEO_BODY_FONT_SIZE=42
# VIDEO_WIDTH=1920
# VIDEO_HEIGHT=1080
# VIDEO_FPS=30
# VIDEO_SCENE_SEC=5
# VIDEO_CRF=18                           # lower = higher quality (15–23 typical)
# VIDEO_PRESET=medium                    # ultrafast|fast|medium|slow
# VIDEO_BG_COLOR=#0f172a
# VIDEO_TEXT_COLOR=#f8fafc
# VIDEO_ACCENT_COLOR=#38bdf8
# VIDEO_TTS=edge                         # edge | none
# VIDEO_TTS_VOICE=en-US-GuyNeural
# VIDEO_COMPOSE_SCRIPT=auto              # auto | llm | template
# Example: arka compose_video --topic "Python asyncio" --llm


# =============================================================================
# Vision — describe image / OCR (local vLLM or Gemini)
# =============================================================================
# DESCRIBE_IMAGE_MODEL=
# DESCRIBE_IMAGE_TWO_LAYER=1
# DESCRIBE_IMAGE_OCR=1
# DESCRIBE_IMAGE_VLLM_START_CMD=


# =============================================================================
# Agent orchestration — handoff, fanout, PR check
# =============================================================================
# HANDOFF_TIMEOUT=600
# FANOUT_TIMEOUT=900
# FANOUT_WORKERS=4
# PR_CHECK_MAX_DIFF=14000
# PR_CHECK_MAX_LOG=9000
# PR_CHECK_POLL_SEC=20


# =============================================================================
# Spotify, vault & misc integrations
# =============================================================================
# SPOTIPY_CLIENT_ID=                     # free Developer Dashboard app
# SPOTIPY_CLIENT_SECRET=
# Or: SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET
# SPOTIFY_CDP_URL=                       # Chrome DevTools for DOM control (Linux)
# macOS: Spotify.app — playback via AppleScript (no API key for playback)
# Linux: spotify desktop + playerctl for auto-play

# VAULT_KEY=                             # encrypt password vault at rest
# SPORTS_DEFAULT=cricket                 # default sport for scores
# DISK_CSV=                              # disk usage report output path
# NO_PROGRESS=0                          # disable progress bars
# PROGRESS=1
# HEARTBEAT: arka heartbeat status  |  arka session-memory status


# =============================================================================
# OpenTelemetry / SigNoz — AI & agent observability (opt-in, default OFF)
# =============================================================================
# OTEL_SDK_DISABLED=true           # master kill switch — disables all OTLP export
# OTEL_TRACES_ENABLED=1            # required to enable traces (SIGNOZ_ENDPOINT alone is not enough)
# OTEL_METRICS_ENABLED=1           # default on when traces enabled
# OTEL_LOGS_ENABLED=1              # default on when traces enabled
# OTEL_SERVICE_NAME=arka
# OTEL_SERVICE_NAMESPACE=arka-agent
# SIGNOZ_ENDPOINT=http://localhost:4318
# SIGNOZ_UI_URL=http://localhost:8080
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# OTEL_EXPORTER_OTLP_TIMEOUT=2     # seconds — short timeout avoids export retry spam
# OTEL_SKIP_ENDPOINT_PROBE=1       # skip TCP probe (start export even if collector is down)
# Inspect: arka signoz status  |  arka signoz demo  |  python3 bin/arka_llm.py trace-status
