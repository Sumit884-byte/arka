# Railway hosted Arka coding/devtool profile.
# Copy these into Railway Variables. Do not commit real secrets.

ARKA_HOSTED_MODE=1
ARKA_REMOTE_PROFILE=coding
ARKA_MCP_ENABLE_PERSONAL_SKILLS=0
REMOTE_HOST=0.0.0.0

# Required for API calls. Generate locally:
# python - <<'PY'
# import secrets
# print(secrets.token_urlsafe(32))
# PY
REMOTE_TOKEN=replace-with-long-random-token

# Optional model/provider credentials for hosted coding answers.
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# Optional GitHub integration for PR/check workflows.
# GITHUB_TOKEN=
