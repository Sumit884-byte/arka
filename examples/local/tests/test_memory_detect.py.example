#!/usr/bin/env python3
"""Unit tests for arka_memory_detect rules (local dev — not committed)."""

from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[2]
sys.path.insert(0, str(ROOT))

from arka_memory_detect import extract_fact  # noqa: E402

CASES: list[tuple[str, str | None]] = [
    ("remember that my dog is named Max", "User's dog is named Max"),
    ("I prefer Hindi TTS", "User prefers Hindi TTS"),
    ("my favorite color is blue", "User's favorite color is blue"),
    ("I'm from Kolkata", "User is from Kolkata"),
    ("I live in Mumbai", "User lives in Mumbai"),
    ("what is the weather", None),
    ("play bohemian rhapsody", None),
    ("what do you remember about Max", None),
    ("my email is test@example.com", "User's email is test@example.com"),
    ("I'm allergic to peanuts", "User is allergic to peanuts"),
    ("facing hair loss", None),
]


def main() -> int:
    failed = 0
    for utterance, want in CASES:
        got = extract_fact(utterance)
        if want is None:
            ok = not got
        else:
            ok = want.lower() in (got or "").lower()
        mark = "ok" if ok else "FAIL"
        if not ok:
            failed += 1
        print(f"{mark}: {utterance!r} -> {got!r} (want {want!r})")
    return 1 if failed else 0


if __name__ == "__main__":
    raise SystemExit(main())
